# Copy this file to .env for local development.
# On Render, set these as environment variables in the dashboard instead
# (render.yaml declares them but leaves the values unset — never commit
# real secrets to the repo).

SUPABASE_URL=
SUPABASE_KEY=
GEMINI_API_KEY=

# Comma-separated list of production frontend origins allowed to call
# this API, e.g. https://nutriwise.vercel.app — only needed on the
# deployed backend (Render), not for local dev (localhost is always
# allowed, see backend/app/main.py).
ALLOWED_ORIGINS=
