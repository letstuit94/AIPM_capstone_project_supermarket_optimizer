# =====================================================================
# NutriWise / Nährbert — environment template
#
# This project keeps ONE .env at the repo ROOT for both backend and
# frontend:
#   - backend reads it via pydantic Settings (backend/app/core/config.py,
#     env_file = <repo root>/.env)
#   - Vite reads it via `envDir: '..'` (frontend/vite.config.ts); only
#     VITE_-prefixed vars are exposed to the browser.
#
# Copy to `.env` and fill in the values (`.env` is gitignored — never
# commit real secrets). On the deploy platforms set these as project
# environment variables instead (Render for the backend, Vercel for the
# frontend).
# =====================================================================

# ── Backend (server-side only) ───────────────────────────────────────
# Supabase project. Find these under: Supabase → Project Settings → API.
SUPABASE_URL=https://<your-project-ref>.supabase.co
# SERVICE-ROLE key — full access, bypasses RLS. SERVER-ONLY, never ship
# to the browser. (The backend enforces per-user scoping in code.)
SUPABASE_KEY=

# Optional: only needed as a fallback for legacy HS256 access tokens.
# Asymmetric tokens are verified via the JWKS endpoint derived from
# SUPABASE_URL, so this can usually stay empty. (Settings → API → JWT.)
SUPABASE_JWT_SECRET=

# Nutri-Coach LLM (services/nutri_coach.py). Set to false for local dev /
# offline demos (no key, no quota) — the coach then uses the rule-based
# template. Defaults to true.
COACH_LLM_ENABLED=true
# Google Gemini key, used only when COACH_LLM_ENABLED=true.
GEMINI_API_KEY=

# CORS: comma-separated list of allowed frontend origins (backend/app/main.py).
# Empty = none allowed; set to your frontend URL(s) in production,
# e.g. https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

# ── Frontend (VITE_*, browser-exposed) ───────────────────────────────
# Base URL of the backend API. Local default below; in production point
# it at the deployed Render backend (e.g. https://<app>.onrender.com).
VITE_API_BASE_URL=http://localhost:8000

# Public, browser-safe Supabase values (anon key is designed to ship to
# the client; RLS + the backend JWT check protect the data).
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
